@model Entities.Domain.ExamResult
@{
    ViewData["Title"] = "Add Exam Result";
    var exam = ViewBag.Exam as Entities.Domain.Exam;
}

<h1>Add Exam Result</h1>
<h5 class="text-muted">@exam?.Title — Max Score: @exam?.MaxScore</h5>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="AddResult">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="ExamId" value="@exam?.Id" />

            <div class="form-group mb-3">
                <label asp-for="StudentProfileId" class="control-label"></label>
                <select asp-for="StudentProfileId" class="form-control"
                        asp-items="ViewBag.StudentProfileId">
                    <option value="">-- Select Student --</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Score" class="control-label"></label>
                <input asp-for="Score" class="form-control" type="number"
                       min="0" max="@exam?.MaxScore" />
                <small class="text-muted">Max: @exam?.MaxScore</small>
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Grade" class="control-label"></label>
                <select asp-for="Grade" class="form-control">
                    <option value="">-- Auto Calculate --</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                    <option value="C">C</option>
                    <option value="F">F</option>
                </select>
                <small class="text-muted">Leave blank to auto calculate from score</small>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Results" asp-route-examId="@exam?.Id"
                   class="btn btn-secondary ms-2">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}