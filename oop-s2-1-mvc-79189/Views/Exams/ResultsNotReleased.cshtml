@model Entities.Domain.Exam
@{
    ViewData["Title"] = "Results Not Available";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="display-1">🔒</div>
            <h1 class="mt-3">Results Not Yet Available</h1>
            <p class="text-muted mt-3">
                The results for <strong>@Model.Title</strong> have not been
                released yet. Please check back later.
            </p>
            <a asp-action="Index" class="btn btn-primary mt-3">Back to Exams</a>
        </div>
    </div>
</div>