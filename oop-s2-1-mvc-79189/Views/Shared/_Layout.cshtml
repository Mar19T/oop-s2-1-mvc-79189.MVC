<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VGC College</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/oop_s2_1_mvc_79189.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    VGC College
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">

                        @* Admin links *@
                        @if (User.IsInRole("Administrator"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Branches" asp-action="Index">Branches</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Courses" asp-action="Index">Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="StudentProfiles" asp-action="Index">Students</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="FacultyProfiles" asp-action="Index">Faculty</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Enrolments" asp-action="Index">Enrolments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Attendance" asp-action="Index">Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Gradebook" asp-action="Index">Gradebook</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a>
                            </li>
                        }

                        @* Faculty links *@
                        @if (User.IsInRole("Faculty"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="FacultyProfiles" asp-action="Index">My Profile</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Enrolments" asp-action="Index">My Students</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Attendance" asp-action="Index">Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Gradebook" asp-action="Index">Gradebook</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a>
                            </li>
                        }

                        @* Student links *@
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="StudentProfiles" asp-action="Index">My Profile</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Enrolments" asp-action="Index">My Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Attendance" asp-action="Index">My Attendance</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Gradebook" asp-action="Index">Gradebook</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a>
                            </li>
                        }

                    </ul>

                    @* Login/Logout *@
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-muted">
                                    Hello @User.Identity.Name!
                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <span class="badge bg-danger ms-1">Admin</span>
                                    }
                                    else if (User.IsInRole("Faculty"))
                                    {
                                        <span class="badge bg-primary ms-1">Faculty</span>
                                    }
                                    else if (User.IsInRole("Student"))
                                    {
                                        <span class="badge bg-success ms-1">Student</span>
                                    }
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout"
                                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                                      method="post">
                                    <button type="submit" class="nav-link btn btn-link">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 VGC College
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>