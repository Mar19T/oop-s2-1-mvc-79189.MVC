@model Entities.Domain.AttendanceRecord
@{
    ViewData["Title"] = "Edit Attendance";
}

<h1>Edit Attendance</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CourseEnrolmentId" />

            <div class="form-group mb-3">
                <label class="control-label">Student & Course</label>
                <input type="text" class="form-control"
                       value="@ViewBag.EnrolmentDisplay" disabled />
            </div>

            <div class="form-group mb-3">
                <label asp-for="WeekNumber" class="control-label"></label>
                <input asp-for="WeekNumber" class="form-control"
                       type="number" min="1" max="52" />
                <span asp-validation-for="WeekNumber" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Date" class="control-label"></label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <div class="form-check">
                    <input asp-for="Present" class="form-check-input" type="checkbox" />
                    <label asp-for="Present" class="form-check-label">Present</label>
                </div>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}