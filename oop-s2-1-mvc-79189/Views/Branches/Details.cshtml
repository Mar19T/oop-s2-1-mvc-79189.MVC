@model Entities.Domain.Branch
@{
    ViewData["Title"] = "Branch Details";
}

<h1>@Model.Name</h1>
<hr />

<dl class="row">
    <dt class="col-sm-2">Address</dt>
    <dd class="col-sm-10">@Model.Address</dd>
    <dt class="col-sm-2">Courses</dt>
    <dd class="col-sm-10">@Model.Courses.Count courses</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary ms-2">Back</a>