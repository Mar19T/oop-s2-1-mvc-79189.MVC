@model Entities.Domain.Branch
@{
    ViewData["Title"] = "Branch Details";
}

<h1>@Model.Name</h1>
<p class="text-muted">@Model.Address</p>
<hr />

@foreach (var course in Model.Courses)
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@course.Name</h5>
            <small class="text-muted">
                @course.StartDate.ToString("dd MMM yyyy") —
                @course.EndDate.ToString("dd MMM yyyy")
            </small>
        </div>
        <div class="card-body">
            <div class="row">

                <!-- Faculty -->
                <div class="col-md-4">
                    <h6 class="text-primary">Faculty</h6>
                    @if (course.FacultyAssignments.Any())
                    {
                        <ul class="list-unstyled">
                            @foreach (var fa in course.FacultyAssignments)
                            {
                                <li>
                                    <span class="badge bg-primary me-1">F</span>
                                    @fa.FacultyProfile?.Name
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted small">No faculty assigned</p>
                    }
                </div>

                <!-- Students -->
                <div class="col-md-8">
                    <h6 class="text-success">
                        Enrolled Students
                        <span class="badge bg-success ms-1">@course.Enrolments.Count</span>
                    </h6>
                    @if (course.Enrolments.Any())
                    {
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Student No.</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var enrolment in course.Enrolments)
                                {
                                    <tr>
                                        <td>@enrolment.StudentProfile?.Name</td>
                                        <td>@enrolment.StudentProfile?.StudentNumber</td>
                                        <td>
                                            <span class="badge @(enrolment.Status == Entities.Domain.EnrolmentStatus.Active ? "bg-success" : enrolment.Status == Entities.Domain.EnrolmentStatus.Withdrawn ? "bg-danger" : "bg-secondary")">
                                                @enrolment.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted small">No students enrolled</p>
                    }
                </div>

            </div>
        </div>
    </div>
}

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary ms-2">Back</a>